{
  "name": "engram-zerotoken",
  "version": "2.0.0",
  "description": "Sistema de memoria persistente entre sesiones para opencode. Engram + ZeroToken (v2 — hardened auto-save, FTS5 trigram, zero-token policy doc).",
  "type": "module",
  "main": "src/engram.ts",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "bun test test/",
    "test:render": "bun test test/render.test.ts",
    "test:decay": "bun test test/decay.test.ts",
    "test:graph": "bun test test/graph.test.ts",
    "test:commands": "bun test test/commands.test.ts",
    "test:engram": "bun test test/engram.test.ts",
    "test:auto-save": "bun test test/auto-save.test.ts",
    "test:smoke": "bash test/smoke.sh",
    "clean": "rm -rf node_modules"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@opencode-ai/plugin": "^1.16.2",
    "@types/node": "^25.9.2",
    "tsx": "^4.22.4",
    "typescript": "^5.8.0"
  }
}
