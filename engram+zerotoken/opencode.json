{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "grep": "deny",
    "glob": "deny",
    "webfetch": "deny",
    "question": "deny",
    "skill": "deny",
    "todowrite": "deny"
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 5000
  },
  "instructions": ["AGENTS.md"],
  "mcp": {
    "context7": { "enabled": false },
    "sqlite": { "enabled": false }
  },
  "plugin": [
    [
      "./src/engram.ts",
      {
        "auto_save": {
          "keywords": true,
          "error_fix": true,
          "compaction": true,
          "architecture": true
        },
        "injection": {
          "enabled": true,
          "max_memories": 2,
          "max_tokens": 600
        }
      }
    ]
  ]
}
