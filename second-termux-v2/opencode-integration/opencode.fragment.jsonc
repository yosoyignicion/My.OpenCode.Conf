{
  "$schema": "https://opencode.ai/config.json",
  "_comment": "Template fragment. The installer (install.sh) replaces __SECOND_TERMUX_REPO__ and __SECOND_TERMUX_SERVER_JS__ with the actual paths on the user's machine. You don't need to edit this file manually — just run ./install.sh.",
  "skills": {
    "paths": [
      "__SECOND_TERMUX_SKILL_PATH__"
    ]
  },
  "mcp": {
    "second-termux": {
      "type": "local",
      "command": [
        "node",
        "__SECOND_TERMUX_SERVER_JS__"
      ],
      "enabled": true,
      "timeout": 30000
    }
  }
}
