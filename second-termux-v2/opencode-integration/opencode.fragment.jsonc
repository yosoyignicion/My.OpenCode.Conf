{
  "$schema": "https://opencode.ai/config.json",
  "//": "Bundle fragment for my-opencode. Substitute <REPO> with `realpath` of the cloned bundle directory. The installer (see README.md 'Prompt maestro') does this automatically. No install.sh — the prompt in README is the only install path.",
  "skills": {
    "paths": [
      "<REPO>/skill-matrix/skills-matrix",
      "<REPO>/second-termux-v2/opencode-integration"
    ]
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "sqlite": {
      "type": "local",
      "command": ["npx", "-y", "mcp-sqlite", "./data.db"],
      "enabled": true
    },
    "second-termux": {
      "type": "local",
      "command": ["node", "<REPO>/second-termux-v2/dist/src/server.js"],
      "enabled": true,
      "timeout": 30000
    }
  },
  "plugin": [
    "file://<REPO>/engram+zerotoken/src/engram.ts"
  ]
}
